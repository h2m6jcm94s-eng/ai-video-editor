# Cloudflare R2 / S3-compatible storage
# Production: Cloudflare R2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=ai-video-editor

# Local development with MinIO (infra/local/docker-compose.yml)
# Copy these into apps/api/.env.local when running locally:
# R2_ENDPOINT=http://localhost:9000
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin
# R2_BUCKET_NAME=ai-video-editor

# AI Provider selection (single name or comma-separated fallback chain)
# Options: programmatic, claude, gemini, kimi, groq, openrouter, openai, qwen
AI_PROVIDER=programmatic

# Override AI provider specifically for tool-call operations (prompt edit / JSON Patch).
# When set, applyPromptEdit uses this instead of AI_PROVIDER. Falls back to AI_PROVIDER if unset.
# Set to "kimi" to promote Kimi K2.6 as primary for tool calls (cheaper, excellent at structured output).
AI_PROVIDER_TOOLCALL=

# AI API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
GOOGLE_API_KEY=AIza...
KIMI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
QWEN_API_KEY=sk-...

# Infrastructure
REDIS_URL=redis://localhost:6379
TEMPORAL_HOST=localhost:7233
DATABASE_URL=postgresql://ave:ave@localhost:5432/ave

# Monitoring (optional)
METRICS_AUTH_TOKEN=change-me-in-production

# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Guardrails sidecar (optional — AI safety)
GUARDRAILS_URL=http://localhost:8000
GUARDRAILS_TIMEOUT_MS=3000
GUARDRAILS_ENABLED=true

# Token budget (optional — per-user daily AI token limits)
DEFAULT_DAILY_TOKEN_LIMIT=100000

# Internal worker token — shared secret for Temporal workers → API callbacks
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_WORKER_TOKEN=

# Encryption — AES-256-GCM KEK for provider API keys (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_KEK=

# Modal (optional, for GPU workers)
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# E2E Test Harness
E2E_BASE_URL=http://localhost:3000
E2E_TEST_USER_EMAIL=test@gmail.com
E2E_TEST_USER_PASSWORD=change-me-for-e2e-tests
PEXELS_API_KEY=
FREESOUND_API_TOKEN=
