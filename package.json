{
  "name": "ai-video-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "obs:up": "docker compose -f infra/observability/docker-compose.yml up -d",
    "obs:down": "docker compose -f infra/observability/docker-compose.yml down",
    "obs:logs": "docker compose -f infra/observability/docker-compose.yml logs -f",
    "branch:clean": "bash scripts/clean-branches.sh",
    "fixtures": "bash scripts/download-fixtures.sh",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:headed": "playwright test --headed --config e2e/playwright.config.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@playwright/test": "^1.60.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.5",
    "tsx": "^4.11.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
