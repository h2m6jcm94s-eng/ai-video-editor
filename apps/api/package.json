{
  "name": "@ai-video-editor/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --include ../../packages/shared-types/dist src/index.ts",
    "start": "node --require ./dist/lib/tracing.js dist/index.js",
    "lint": "eslint --ext .ts src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-video-editor/shared-types": "workspace:*",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@clerk/fastify": "^1.0.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@temporalio/client": "^1.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.31.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.4.0",
    "js-tiktoken": "^1.0.21",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "postgres": "^3.4.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@ai-video-editor/eslint-config": "workspace:*",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.22.0",
    "eslint": "^8.57.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
