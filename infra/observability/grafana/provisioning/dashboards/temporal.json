      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=~\"ingest-worker|render-worker\"} |= \"workflow\"",
          "refId": "A"
        }
      ],
      "title": "Worker Workflow Logs",
      "type": "logs"
