FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    ffmpeg \
    libsm6 \
    libxext6 \
    libgl1-mesa-glx \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY services/shared-py ./shared-py
COPY services/ingest-worker ./ingest-worker
COPY pyproject.toml .
COPY uv.lock .

RUN pip install --no-cache-dir uv && \
    uv pip install -e ./shared-py -e ./ingest-worker

CMD ["python", "-m", "ingest_worker"]
